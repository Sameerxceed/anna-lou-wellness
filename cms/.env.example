# Anna Lou Wellness CMS — Environment Variables
# Copy to .env and fill in values

# Server
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=http://localhost:1337

# Security Keys (generate unique values for production!)
APP_KEYS=key1-change-me,key2-change-me
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
API_TOKEN_SALT=change-me-api-token-salt
TRANSFER_TOKEN_SALT=change-me-transfer-salt
JWT_SECRET=change-me-jwt-secret

# Database (SQLite for dev — no config needed)
# For PostgreSQL (production):
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=anna_lou_wellness
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=your-password
# DATABASE_SSL=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:4321

# Cloudinary (optional — for image CDN)
# CLOUDINARY_NAME=your-cloud-name
# CLOUDINARY_KEY=your-api-key
# CLOUDINARY_SECRET=your-api-secret

# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Email notifications
# NOTIFICATION_EMAIL=hello@annalouwellness.com
# SHOP_EMAIL=hello@annalouwellness.com

# Seed script token (create in Strapi admin → Settings → API Tokens)
# SEED_TOKEN=your-full-access-api-token

{
  "collectionName": "components_sections_galleries",
  "info": {
    "displayName": "Gallery",
    "icon": "images",
    "description": "Image gallery with layout options"
  },
  "attributes": {
    "heading": {
      "type": "string"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ],
      "required": true
    },
    "layout": {
      "type": "enumeration",
      "enum": [
        "grid",
        "masonry",
        "slider"
      ],
      "default": "grid"
    },
    "style": {
      "type": "component",
      "repeatable": false,
      "component": "shared.section-style",
      "description": "Optional background colour, text colour, padding, alignment, max width, and background image for this section. Leave any field blank to use defaults."
    }
  }
}

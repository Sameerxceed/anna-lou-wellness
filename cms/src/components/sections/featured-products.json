{
  "collectionName": "components_sections_featured_products",
  "info": {
    "displayName": "Featured Products",
    "icon": "shopping-cart",
    "description": "Showcase selected products from the shop"
  },
  "attributes": {
    "heading": {
      "type": "string"
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    },
    "columns": {
      "type": "enumeration",
      "enum": [
        "2",
        "3",
        "4"
      ],
      "default": "4"
    },
    "style": {
      "type": "component",
      "repeatable": false,
      "component": "shared.section-style",
      "description": "Optional background colour, text colour, padding, alignment, max width, and background image for this section. Leave any field blank to use defaults."
    }
  }
}

{
  "kind": "collectionType",
  "collectionName": "faqs",
  "info": {
    "singularName": "faq",
    "pluralName": "faqs",
    "displayName": "FAQ · Per Page",
    "description": "Frequently asked questions. Each entry binds to one page (e.g. The Reset, Retreats, Reset Room). Auto-renders as accordion on the page + JSON-LD schema for AI/Google rich snippets."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "question": {
      "type": "string",
      "required": true
    },
    "answer": {
      "type": "richtext",
      "required": true
    },
    "page": {
      "type": "enumeration",
      "enum": [
        "the-reset",
        "signal",
        "signal-and-build",
        "one-day",
        "signal-collective",
        "sessions",
        "recovery",
        "quiz",
        "the-work",
        "retreats",
        "workshops",
        "corporate-wellbeing",
        "speaking",
        "reset-room",
        "the-returning-circle",
        "membership",
        "events",
        "resources",
        "shop",
        "about",
        "contact",
        "testimonials",
        "ask-anna",
        "decoder",
        "general"
      ],
      "default": "general"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "coaching",
        "shop",
        "membership",
        "experiences",
        "general"
      ]
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}

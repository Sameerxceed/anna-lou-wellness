{
  "kind": "singleType",
  "collectionName": "homepages",
  "info": {
    "singularName": "homepage",
    "pluralName": "homepages",
    "displayName": "Homepage",
    "description": "Homepage content"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "hero_title": {
      "type": "string",
      "default": "Beautifully Whole"

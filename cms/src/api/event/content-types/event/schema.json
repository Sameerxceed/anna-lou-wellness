{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "zz · Event (unused)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "date": {
      "type": "date",
      "required": true,
      "description": "Click the month name at top of the picker to jump months/years. Use the < > arrows to step one month at a time. Leave empty for evergreen items (no fixed date)."
    },
    "time": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "event_type": {
      "type": "enumeration",
      "enum": [
        "Salon",
        "Open Day",
        "Music Walk",
        "Meditation",
        "Gathering",
        "Dining",
        "Festival",
        "Workshop",
        "Other"
      ]
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "booking_url": {
      "type": "string",
      "description": "Where the 'Book now' / 'Buy' button takes people. Examples: https://buy.stripe.com/abcd, https://calendly.com/anna/intro, or a path like /the-work/regulated. Leave blank to hide the button."
    },
    "is_published": {
      "type": "boolean",
      "default": true
    }
  }
}

    },
    "short_description": {
      "type": "string",
      "required": true
    },
    "full_description": {
      "type": "richtext"
    },
    "card_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ],
      "required": true
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "is_visible": {
      "type": "boolean",
      "default": true
    }
  }
}
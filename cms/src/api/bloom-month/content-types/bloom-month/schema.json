{
  "kind": "collectionType",
  "collectionName": "bloom_months",
  "info": {
    "singularName": "bloom-month",
    "pluralName": "bloom-months",
    "displayName": "In Bloom",
    "description": "Monthly bloom calendar"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "month": {
      "type": "enumeration",
      "enum": [
        "January",
        "February",
        "March",
        "April",
        "May",
        "June",
        "July",
        "August",
        "September",
        "October",
        "November",
        "December"
      ],
      "required": true
    },
    "year": {
      "type": "integer",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "plants_in_bloom": {
      "type": "richtext"
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "is_current": {
      "type": "boolean",
      "default": false
    }
  }
}
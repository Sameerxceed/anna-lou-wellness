{
  "kind": "singleType",
  "collectionName": "cottages",
  "info": {
    "singularName": "cottage",
    "pluralName": "cottages",
    "displayName": "Stay"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "headline": {
      "type": "string",
      "default": "The Honeymoon Stone Cottage"
    },
    "description": {
      "type": "richtext"
    },
    "long_description": {
      "type": "richtext"
    },
    "nightly_rate": {
      "type": "decimal",
      "required": true
    },
    "minimum_nights": {
      "type": "integer",
      "default": 5
    },
    "check_in_time": {
      "type": "string",
      "default": "3:00 PM"
    },
    "check_out_time": {
      "type": "string",
      "default": "11:00 AM"
    },
    "amenities": {
      "type": "richtext"
    },
    "house_rules": {
      "type": "richtext"
    },
    "booking_com_url": {
      "type": "string"
    },
    "airbnb_url": {
      "type": "string"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "dining_info": {
      "type": "richtext"
    },
    "nearby_attractions": {
      "type": "text"
    }
  }
}
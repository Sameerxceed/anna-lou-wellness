{
  "kind": "collectionType",
  "collectionName": "product_options",
  "info": {
    "singularName": "product-option",
    "pluralName": "product-options",
    "displayName": "zz \u00b7 Product Option (unused)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "options"
    },
    "name": {
      "type": "string",
      "required": true
    },
    "values": {
      "type": "json",
      "required": true
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    }
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": false
    }
  }
}

{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Shop \u00b7 Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "order_number": {
      "type": "string",
      "unique": true,
      "required": true
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer",
      "inversedBy": "orders"
    },
    "customer_name": {
      "type": "string",
      "required": true
    },
    "customer_email": {
      "type": "email",
      "required": true
    },
    "customer_phone": {
      "type": "string"
    },
    "shipping_address": {
      "type": "text",
      "required": true
    },
    "items": {
      "type": "json",
      "required": true
    },
    "subtotal": {
      "type": "decimal",
      "required": true
    },
    "discount_amount": {
      "type": "decimal",
      "default": 0
    },
    "coupon_code": {
      "type": "string"
    },
    "tax_amount": {
      "type": "decimal",
      "default": 0
    },
    "tax_breakdown": {
      "type": "json",
      "default": []
    },
    "shipping_cost": {
      "type": "decimal",
      "default": 0
    },
    "shipping_method": {
      "type": "string"
    },
    "total": {
      "type": "decimal",
      "required": true
    },
    "currency": {
      "type": "string",
      "default": "gbp"
    },
    "exchange_rate": {
      "type": "decimal",
      "default": 1.0
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "paid",
        "shipped",
        "completed",
        "cancelled",
        "refunded"
      ],
      "default": "pending"
    },
    "payment_method": {
      "type": "enumeration",
      "enum": [
        "stripe",
        "paypal",
        "bank_transfer"
      ],
      "required": true
    },
    "stripe_payment_id": {
      "type": "string"
    },
    "notes": {
      "type": "text"
    },
    "tracking_number": {
      "type": "string",
      "description": "Carrier tracking reference. Filled in when marking the order shipped."
    },
    "tracking_url": {
      "type": "string",
      "description": "Direct link the customer can click to track their parcel."
    },
    "shipping_carrier": {
      "type": "string",
      "description": "Royal Mail, DPD, Evri, etc. Appears in the shipping confirmation email."
    },
    "shipped_at": {
      "type": "datetime"
    },
    "cancellation_reason": {
      "type": "text",
      "description": "Short reason shown to the customer when an order is cancelled."
    },
    "refund_amount": {
      "type": "decimal",
      "description": "Amount refunded to the customer. Auto-filled from Stripe for card refunds."
    },
    "refunded_at": {
      "type": "datetime"
    },
    "return_requests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::return-request.return-request",
      "mappedBy": "order"
    }
  }
}

{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Orders"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "order_number": {
      "type": "string",
      "unique": true,
      "required": true
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer",
      "inversedBy": "orders"
    },
    "customer_name": {
      "type": "string",
      "required": true
    },
    "customer_email": {
      "type": "email",
      "required": true
    },
    "customer_phone": {
      "type": "string"
    },
    "shipping_address": {
      "type": "text",
      "required": true
    },
    "items": {
      "type": "json",
      "required": true
    },
    "subtotal": {
      "type": "decimal",
      "required": true
    },
    "discount_amount": {
      "type": "decimal",
      "default": 0
    },
    "coupon_code": {
      "type": "string"
    },
    "tax_amount": {
      "type": "decimal",
      "default": 0
    },
    "tax_breakdown": {
      "type": "json",
      "default": []
    },
    "shipping_cost": {
      "type": "decimal",
      "default": 0
    },
    "shipping_method": {
      "type": "string"
    },
    "total": {
      "type": "decimal",
      "required": true
    },
    "currency": {
      "type": "string",
      "default": "EUR"
    },
    "exchange_rate": {
      "type": "decimal",
      "default": 1.0
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "paid", "shipped", "completed", "cancelled", "refunded"],
      "default": "pending"
    },
    "payment_method": {
      "type": "enumeration",
      "enum": ["stripe", "paypal", "bank_transfer"],
      "required": true
    },
    "stripe_payment_id": {
      "type": "string"
    },
    "notes": {
      "type": "text"
    },
    "return_requests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::return-request.return-request",
      "mappedBy": "order"
    }
  }
}

{
    "kind":  "collectionType",
    "collectionName":  "testimonials",
    "info":  {
                 "singularName":  "testimonial",
                 "pluralName":  "testimonials",
                 "displayName":  "Testimonial / Review",
                 "description":  "Client reviews shown on retreat, workshop, coaching and programme pages. Mix of text quotes and short videos."
             },
    "options":  {
                    "draftAndPublish":  true
                },
    "attributes":  {
                       "reviewer_name":  {
                                             "type":  "string",
                                             "required":  true
                                         },
                       "reviewer_location":  {
                                                 "type":  "string",
                                                 "description":  "Optional. e.g. \u0027London, UK\u0027 or \u0027Programme alumna 2025\u0027"
                                             },
                       "quote":  {
                                     "type":  "text",
                                     "description":  "The review text. Required if no video. Keep tight â€” 1-3 sentences reads best."
                                 },
                       "rating":  {
                                      "type":  "integer",
                                      "min":  1,
                                      "max":  5,
                                      "description":  "Optional 1-5 star rating. Leave blank to hide stars."
                                  },
                       "photo":  {
                                     "type":  "media",
                                     "multiple":  false,
                                     "allowedTypes":  [
                                                          "images"
                                                      ],
                                     "description":  "Optional portrait photo of the client. Shown as a circular/octagonal frame next to the quote on the /testimonials page. Best size 800Ã—800 (square), JPEG, max 500 KB."
                                 },
                       "video":  {
                                     "type":  "media",
                                     "multiple":  false,
                                     "allowedTypes":  [
                                                          "videos"
                                                      ],
                                     "description":  "Optional uploaded video testimonial (MP4, under 90 seconds recommended)."
                                 },
                       "video_thumbnail":  {
                                               "type":  "media",
                                               "multiple":  false,
                                               "allowedTypes":  [
                                                                    "images"
                                                                ],
                                               "description":  "Optional poster image shown before the video plays."
                                           },
                       "youtube_url":  {
                                           "type":  "string",
                                           "description":  "Optional â€” paste a YouTube video URL to embed instead of uploading. Either this or \u0027video\u0027 (not both). Accepts standard youtube.com/watch?v=... or youtu.be/... links."
                                       },
                       "display_style":  {
                                             "type":  "enumeration",
                                             "enum":  [
                                                          "card",
                                                          "banner"
                                                      ],
                                             "default":  "card",
                                             "description":  "How this testimonial renders on the dedicated /testimonials page. \u0027card\u0027 = standard 3-column grid item. \u0027banner\u0027 = full-width prominent block between rows (use for your strongest testimonials, 1 in every 6-10 entries)."
                                         },
                       "date":  {
                                    "type":  "customField",
                                    "customField":  "global::alw-date",
                                    "description":  "When the review was given (sort by recency)."
                                },
                       "tags":  {
                                    "type":  "enumeration",
                                    "enum":  [
                                                 "retreats",
                                                 "workshops",
                                                 "corporate",
                                                 "speaking",
                                                 "coaching",
                                                 "the-reset",
                                                 "signal",
                                                 "signal-and-build",
                                                 "reset-room",
                                                 "one-day",
                                                 "collective",
                                                 "reset-session"
                                             ],
                                    "description":  "Page tag â€” used when a review applies to a section page rather than a specific experience."
                                },
                       "experiences":  {
                                           "type":  "relation",
                                           "relation":  "manyToMany",
                                           "target":  "api::experience.experience",
                                           "description":  "Specific retreats/workshops this review belongs to. Leave blank if it\u0027s a general coaching review (use the tag instead)."
                                       },
                       "is_featured":  {
                                           "type":  "boolean",
                                           "default":  false,
                                           "description":  "Show on the homepage testimonial strip."
                                       },
                       "is_active":  {
                                         "type":  "boolean",
                                         "default":  true,
                                         "description":  "Untick to HIDE this entry from the public site without deleting it. Useful for seasonal items or things you\u0027re drafting privately."
                                     },
                       "sort_order":  {
                                          "type":  "integer",
                                          "default":  0,
                                          "description":  "Lower numbers appear first. Use to surface strongest reviews."
                                      }
                   }
}


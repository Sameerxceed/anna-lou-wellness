{
  "kind": "collectionType",
  "collectionName": "coaching_sessions",
  "info": {
    "singularName": "coaching-session",
    "pluralName": "coaching-sessions",
    "displayName": "Work \u00b7 Coaching Session",
    "description": "1:1 coaching session types: Reset Sessions, Founder Reset, Dating Reset, Nervous System Reset"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "duration": {
      "type": "string",
      "description": "e.g. 6 weeks, 12 weeks"
    },
    "price": {
      "type": "decimal"
    },
    "price_label": {
      "type": "string",
      "description": "e.g. Enquire, From GBP 1,500"
    },
    "tagline": {
      "type": "string",
      "description": "Short one-line hook shown on the /the-work/sessions card grid. e.g. 'For the founder at a sticking point in the business or in herself.'"
    },
    "accent_colour": {
      "type": "string",
      "default": "#FAA21B",
      "description": "Hex colour used as the accent line on the session card. Match the section: gold for Founder Reset, pink for Dating Reset, blue for Nervous System Reset."
    },
    "hero_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "text"
    }
  }
}

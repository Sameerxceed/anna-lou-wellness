{
  "kind": "singleType",
  "collectionName": "about_pages",
  "info": {
    "singularName": "about-page",
    "pluralName": "about-pages",
    "displayName": "About",
    "description": "About page content"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "kicker": {
      "type": "string",
      "default": "About"
    },
    "title": {
      "type": "string",
      "default": "Twenty-five years leaves a trail."
    },
    "story_paragraph_1": {
      "type": "richtext"
    },
    "story_paragraph_2": {
      "type": "richtext"
    },
    "portrait": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "press_logos": {
      "type": "component",
      "repeatable": true,
      "component": "about.press-logo"
    },
    "certifications": {
      "type": "component",
      "repeatable": true,
      "component": "about.certification"
    },
    "roles_tagline": {
      "type": "string",
      "default": "Coach. Trainer. Podcaster. Author. Entrepreneur. Designer."
    },
    "additional_bio": {
      "type": "richtext"
    },
    "seo_title": {
      "type": "string",
      "description": "Optional SEO title override (60 chars max). Leave blank to use the page/item name. Shown in Google search results and browser tabs."
    },
    "seo_description": {
      "type": "text",
      "description": "Short summary for Google and ChatGPT (1-2 sentences, ~155 chars). Write what someone searching for this would actually type. Use the 'Generate SEO' button if available, then edit."
    }
  }
}

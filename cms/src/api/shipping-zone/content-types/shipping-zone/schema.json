{
  "kind": "collectionType",
  "collectionName": "shipping_zones",
  "info": {
    "singularName": "shipping-zone",
    "pluralName": "shipping-zones",
    "displayName": "zz \u00b7 Shipping Zone (unused)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "countries": {
      "type": "json",
      "required": true
    },
    "shipping_methods": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::shipping-method.shipping-method",
      "mappedBy": "shipping_zone"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": false
    }
  }
}

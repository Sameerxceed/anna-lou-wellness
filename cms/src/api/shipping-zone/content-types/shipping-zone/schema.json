{
  "kind": "collectionType",
  "collectionName": "shipping_zones",
  "info": {
    "singularName": "shipping-zone",
    "pluralName": "shipping-zones",
    "displayName": "zz · Shipping Zone (unused)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "countries": {
      "type": "string",
      "required": true,
      "description": "Two-letter country codes this zone covers, comma-separated. Example: 'GB, IE' for UK & Ireland; 'US, CA' for North America; 'GB' for UK only."
    },
    "shipping_methods": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::shipping-method.shipping-method",
      "mappedBy": "shipping_zone"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Untick to HIDE this entry from the public site without deleting it. Useful for seasonal items or things you're drafting privately."
    }
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": false
    }
  }
}

{
  "kind": "collectionType",
  "collectionName": "visit_options",
  "info": {
    "singularName": "visit-option",
    "pluralName": "visit-options",
    "displayName": "Plan Your Visit"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "price_text": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    }
  }
}
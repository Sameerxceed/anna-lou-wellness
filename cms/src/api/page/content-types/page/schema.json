{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "zz · Page-legacy (unused)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "template": {
      "type": "enumeration",
      "enum": [
        "default",
        "landing",
        "editorial",
        "services"
      ],
      "default": "default"
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "sections.hero",
        "sections.text-block",
        "sections.card-grid",
        "sections.testimonials",
        "sections.cta-banner",
        "sections.gallery",
        "sections.faq",
        "sections.team-grid",
        "sections.contact-form",
        "sections.embed",
        "sections.featured-products",
        "sections.custom-html",
        "sections.press-strip"
      ]
    },
    "seo_title": {
      "type": "string",
      "description": "Optional SEO title override (60 chars max). Leave blank to use the page/item name. Shown in Google search results and browser tabs."
    },
    "seo_description": {
      "type": "text",
      "description": "Short summary for Google and ChatGPT (1-2 sentences, ~155 chars). Write what someone searching for this would actually type. Use the 'Generate SEO' button if available, then edit."
    },
    "og_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    }
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": false
    }
  }
}

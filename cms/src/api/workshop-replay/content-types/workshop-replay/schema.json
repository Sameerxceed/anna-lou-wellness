{
    "kind":  "collectionType",
    "collectionName":  "workshop_replays",
    "info":  {
                 "singularName":  "workshop-replay",
                 "pluralName":  "workshop-replays",
                 "displayName":  "Reset Room Â· Workshop Replay",
                 "description":  "Recordings of past workshops + monthly live calls. Members-only."
             },
    "options":  {
                    "draftAndPublish":  true
                },
    "attributes":  {
                       "title":  {
                                     "type":  "string",
                                     "required":  true
                                 },
                       "slug":  {
                                    "type":  "uid",
                                    "targetField":  "title",
                                    "required":  true,
                                    "description":  "URL path after the slash. Lowercase, hyphens-not-spaces, no punctuation. Auto-fills from the name/title â€” only edit if you want to change the URL."
                                },
                       "description":  {
                                           "type":  "text",
                                           "description":  "Short description shown on the replay card."
                                       },
                       "kind":  {
                                    "type":  "enumeration",
                                    "enum":  [
                                                 "Monthly live call",
                                                 "Workshop",
                                                 "Q\u0026A session",
                                                 "Special event"
                                             ],
                                    "default":  "Workshop"
                                },
                       "recorded_date":  {
                                             "type":  "customField",
                                             "customField":  "global::alw-date",
                                             "required":  true,
                                             "description":  "When this was recorded. Sorted newest-first on the replays page."
                                         },
                       "duration":  {
                                        "type":  "string",
                                        "description":  "e.g. \u002790 min\u0027 or \u002745 min\u0027."
                                    },
                       "video_url":  {
                                         "type":  "string",
                                         "description":  "Bunny.net Stream embed URL or any iframe-embeddable video URL."
                                     },
                       "video_thumbnail":  {
                                               "type":  "media",
                                               "multiple":  false,
                                               "allowedTypes":  [
                                                                    "images"
                                                                ]
                                           },
                       "audio_file":  {
                                          "type":  "media",
                                          "multiple":  false,
                                          "allowedTypes":  [
                                                               "audios"
                                                           ],
                                          "description":  "Optional audio-only version for the private podcast feed."
                                      },
                       "body":  {
                                    "type":  "richtext",
                                    "description":  "Show notes, summary, links. Markdown."
                                },
                       "is_active":  {
                                         "type":  "boolean",
                                         "default":  true,
                                         "description":  "Untick to HIDE this entry from the public site without deleting it. Useful for seasonal items or things you\u0027re drafting privately."
                                     }
                   }
}


{
  "kind": "collectionType",
  "collectionName": "workshop_replays",
  "info": {
    "singularName": "workshop-replay",
    "pluralName": "workshop-replays",
    "displayName": "Reset Room · Workshop Replay",
    "description": "Recordings of past workshops + monthly live calls. Members-only."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text",
      "description": "Short description shown on the replay card."
    },
    "kind": {
      "type": "enumeration",
      "enum": [
        "Monthly live call",
        "Workshop",
        "Q&A session",
        "Special event"
      ],
      "default": "Workshop"
    },
    "recorded_date": {
      "type": "customField",
      "customField": "global::alw-date",
      "required": true,
      "description": "When this was recorded. Sorted newest-first on the replays page."
    },
    "duration": {
      "type": "string",
      "description": "e.g. '90 min' or '45 min'."
    },
    "video_url": {
      "type": "string",
      "description": "Bunny.net Stream embed URL or any iframe-embeddable video URL."
    },
    "video_thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "audio_file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "audios"
      ],
      "description": "Optional audio-only version for the private podcast feed."
    },
    "body": {
      "type": "richtext",
      "description": "Show notes, summary, links. Markdown."
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}

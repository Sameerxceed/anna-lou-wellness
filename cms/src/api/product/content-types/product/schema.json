{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Shop \u00b7 Product",
    "description": "PHYSICAL items sold via the shop (jewellery, crystals, sage, gifts). For workshops, retreats, or programmes use the 'Experience' or 'Programme' collections instead \u2014 those are services with bookings, not items shipped to a customer."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "short_description": {
      "type": "string"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "compare_at_price": {
      "type": "decimal"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product-category.product-category",
      "inversedBy": "products"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "stock": {
      "type": "integer",
      "default": 0
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "description": "Generic featured flag (in-shop featured product carousel etc.)."
    },
    "is_homepage_featured": {
      "type": "boolean",
      "default": false,
      "description": "Show this product on the homepage 'Jewellery with meaning' preview row. Top 3 by sort_order are displayed."
    },
    "homepage_hook": {
      "type": "text",
      "description": "Italic message shown above the product name on the homepage card, e.g. 'I reach for this one when I need to remember what is underneath the noise.' Keep short, 1 sentence."
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sku": {
      "type": "string"
    },
    "weight_grams": {
      "type": "integer"
    },
    "tax_class": {
      "type": "enumeration",
      "enum": [
        "standard",
        "reduced",
        "zero"
      ],
      "default": "standard"
    },
    "tags": {
      "type": "string",
      "description": "Comma-separated tags for filtering/search (e.g. 'best-seller, gift, new-in'). Leave blank if none."
    },
    "variants": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product-variant.product-variant",
      "mappedBy": "product"
    },
    "options": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product-option.product-option",
      "mappedBy": "product"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product-review.product-review",
      "mappedBy": "product"
    }
  }
}

{
  "kind": "collectionType",
  "collectionName": "return_requests",
  "info": {
    "singularName": "return-request",
    "pluralName": "return-requests",
    "displayName": "Shop · Return Request"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "order": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::order.order",
      "inversedBy": "return_requests",
      "description": "Lower numbers show first. Use 10, 20, 30 (not 1, 2, 3) so you can drop new entries between existing ones without renumbering everything."
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer"
    },
    "items": {
      "type": "json",
      "required": true,
      "description": "List of items being returned (auto-populated from the order)."
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "requested",
        "approved",
        "received",
        "refunded",
        "rejected"
      ],
      "default": "requested",
      "description": "requested → customer just asked. approved → you said yes, here's how to ship it. received → parcel arrived. refunded → money returned. rejected → return not accepted."
    },
    "reason": {
      "type": "enumeration",
      "enum": [
        "damaged",
        "wrong_item",
        "not_as_described",
        "changed_mind",
        "other"
      ],
      "required": true
    },
    "notes": {
      "type": "text",
      "description": "Free-text notes — instructions to customer when approved, or reason when rejected."
    },
    "refund_amount": {
      "type": "decimal"
    },
    "refund_method": {
      "type": "enumeration",
      "enum": [
        "original_payment",
        "store_credit"
      ]
    }
  }
}
